<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    background="#0a0a0a">

    <!-- Dashboard Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ STATUS: CONNECTED ]"
                android:textColor="#00ff9f"
                android:textSize="10sp"
                android:fontFamily="monospace" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RYZEN HUB"
                android:textColor="#ffffff"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="#00ff9f"
            android:textSize="18sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Main Menu Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:padding="16dp"
        android:columnCount="2"
        android:rowCount="2">

        <Button
            android:id="@+id/btnWa"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="WHATSAPP"
            android:backgroundTint="#1a1a1a"
            android:textColor="#00ff9f"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnIg"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="INSTAGRAM"
            android:backgroundTint="#1a1a1a"
            android:textColor="#00ff9f"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnFb"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="FACEBOOK"
            android:backgroundTint="#1a1a1a"
            android:textColor="#00ff9f"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnTh"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="THREADS"
            android:backgroundTint="#1a1a1a"
            android:textColor="#00ff9f"
            android:fontFamily="monospace" />
    </GridLayout>

    <!-- WebView Container (Hidden by default) -->
    <LinearLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#000000">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#1a1a1a">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="50dp"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackground"
                android:tint="#00ff9f" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="SECURE LINK ACTIVE"
                android:textColor="#00ff9f"
                android:fontFamily="monospace"
                android:textSize="12sp" />
            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="50dp"
                android:layout_height="match_parent"
                android:layout_alignParentRight="true"
                android:src="@android:drawable/ic_menu_rotate"
                android:background="?attr/selectableItemBackground"
                android:tint="#00ff9f" />
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressBackgroundTint="#000000"
            android:progressTint="#00ff9f" />

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Hacker Loading Overlay -->
    <RelativeLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#cc0a0a0a"
        android:visibility="gone">
        <TextView
            android:id="@+id/tvLoadingLogs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Initializing..."
            android:textColor="#00ff9f"
            android:fontFamily="monospace"
            android:gravity="center" />
    </RelativeLayout>
</RelativeLayout>
